# T-Ride production proxy template.
# Copy to .env on the new production VPS only. Do not commit real domains,
# private operational email addresses, or secrets.

TRIDE_PRODUCTION_DOMAIN=ride.example.com
ACME_EMAIL=REPLACE_WITH_ACME_EMAIL

# Host 80/443 are for the new production VPS only.
PROXY_HTTP_BIND=0.0.0.0
PROXY_HTTP_PORT=80
PROXY_HTTPS_BIND=0.0.0.0
PROXY_HTTPS_PORT=443

TRIDE_PROD_NETWORK=tride-prod-net
CLIENT_MAX_BODY_SIZE=25MB
