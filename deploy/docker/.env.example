# T-Ride staging Docker Compose — copy to deploy/docker/.env on the server.
# Never commit real secrets. chmod 600 .env

# =============================================================================
# MySQL (tride-db container)
# =============================================================================
MYSQL_ROOT_PASSWORD=replace-with-strong-root-password
DB_NAME=tride_staging
DB_USER=tride_app
DB_PASSWORD=replace-with-strong-app-password

# =============================================================================
# Backend (tride-backend) — staging validation requires strong JWT + explicit CORS
# =============================================================================
JWT_ACCESS_SECRET=replace-with-strong-random-access-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-strong-random-refresh-secret-min-32-chars

# Split-port smoke: UI on :3101, API on :3100 (replace SERVER_IP with Gabia public IP)
CORS_ORIGIN=http://SERVER_IP:3101
PUBLIC_API_URL=http://SERVER_IP:3100

# Optional toggles
SWAGGER_ENABLED=false
FLIGHT_SYNC_ENABLED=false
ALLOW_DEV_QR_REISSUE=false
LOG_LEVEL=info
TZ=Asia/Bangkok

# Optional Google Places proxy (server-side; required for booking destination search)
# Set one of these on the server. Do not commit real API keys.
GOOGLE_MAPS_API_KEY=
# GOOGLE_PLACES_API_KEY=

# =============================================================================
# Frontend build args (rebuild tride-frontend after changing)
# =============================================================================
TRIDE_API_BASE_URL=http://SERVER_IP:3100
# TRIDE_SOCKET_URL=http://SERVER_IP:3100

# Host port mappings (do not use 80/443 — ktaxi-nginx owns those)
TRIDE_BACKEND_HOST_PORT=3100
TRIDE_FRONTEND_HOST_PORT=3101

# =============================================================================
# Future public domain (Phase 5 — ktaxi-nginx; rebuild frontend after DNS/TLS)
# =============================================================================
# CORS_ORIGIN=https://tride-staging.88taxi.net
# PUBLIC_API_URL=https://tride-staging.88taxi.net
# TRIDE_API_BASE_URL=https://tride-staging.88taxi.net
