# T-Ride production environment template.
# Copy to deploy/docker/.env.production on the production server only, then run
# production compose commands with `--env-file deploy/docker/.env.production`.
# Never commit real passwords, JWT secrets, API keys, private keys, or domains.

# =============================================================================
# Required: runtime identity
# =============================================================================
NODE_ENV=production
TZ=Asia/Bangkok

# =============================================================================
# Required: MariaDB
# Use a production-only DB name. Do not reuse staging, ttaxi, ktaxi, or legacy DBs.
# =============================================================================
DB_HOST=tride-prod-db
DB_PORT=3306
DB_NAME=REPLACE_WITH_PRODUCTION_DB_NAME
DB_USER=REPLACE_WITH_PRODUCTION_DB_USER
DB_PASSWORD=REPLACE_WITH_STRONG_PRODUCTION_DB_PASSWORD
MYSQL_ROOT_PASSWORD=REPLACE_WITH_STRONG_PRODUCTION_MYSQL_ROOT_PASSWORD
DB_CONNECTION_LIMIT=10

# =============================================================================
# Required: local container ports
# Bind addresses should normally remain localhost-only. Public 80/443 routing is
# handled by a separately reviewed reverse proxy/TLS change.
# =============================================================================
BACKEND_BIND_ADDRESS=127.0.0.1
BACKEND_PORT=REPLACE_WITH_BACKEND_LOCAL_PORT
FRONTEND_BIND_ADDRESS=127.0.0.1
FRONTEND_PORT=REPLACE_WITH_FRONTEND_LOCAL_PORT

# =============================================================================
# Required: backend auth/session
# Must be long random values from a password manager or secret store.
# =============================================================================
JWT_ACCESS_SECRET=REPLACE_WITH_STRONG_RANDOM_ACCESS_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_STRONG_RANDOM_REFRESH_SECRET_MIN_32_CHARS
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# Required: public URLs and CORS
# Recommended initial topology: same-origin https://tride.example.com
# Do not leave these as localhost or staging URLs in production.
# =============================================================================
ALLOWED_ORIGINS=REPLACE_WITH_HTTPS_PRODUCTION_FRONTEND_ORIGIN
CORS_ORIGIN=REPLACE_WITH_HTTPS_PRODUCTION_FRONTEND_ORIGIN
FRONTEND_PUBLIC_URL=REPLACE_WITH_HTTPS_PRODUCTION_FRONTEND_URL
BACKEND_PUBLIC_URL=REPLACE_WITH_HTTPS_PRODUCTION_BACKEND_URL
PUBLIC_API_URL=REPLACE_WITH_HTTPS_PRODUCTION_BACKEND_URL

# =============================================================================
# Required: frontend build args
# Rebuild tride-prod-frontend after changing these values.
# For same-origin topology, API_BASE_URL and SOCKET_URL can use the same origin.
# =============================================================================
API_BASE_URL=REPLACE_WITH_HTTPS_PRODUCTION_API_BASE_URL
SOCKET_URL=REPLACE_WITH_HTTPS_PRODUCTION_SOCKET_URL
TRIDE_API_BASE_URL=REPLACE_WITH_HTTPS_PRODUCTION_API_BASE_URL

# =============================================================================
# Optional but expected for production booking search
# =============================================================================
GOOGLE_MAPS_API_KEY=REPLACE_WITH_PRODUCTION_GOOGLE_MAPS_API_KEY
GOOGLE_PLACES_API_KEY=

# =============================================================================
# Required: upload and logs
# Compose maps these to persistent named volumes.
# =============================================================================
UPLOAD_ROOT=/srv/tride/uploads
UPLOAD_DIR=/srv/tride/uploads
MAX_UPLOAD_SIZE=10
UPLOAD_MAX_FILE_SIZE_MB=10
LOG_LEVEL=info
LOG_DIR=/srv/tride/logs
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5

# =============================================================================
# Required production safety toggles
# =============================================================================
SWAGGER_ENABLED=false
ALLOW_DEV_QR_REISSUE=false
FLIGHT_SYNC_ENABLED=false

# =============================================================================
# Optional integrations. Fill only on the production server.
# =============================================================================
AVIATIONSTACK_API_KEY=
AVIATIONSTACK_BASE_URL=http://api.aviationstack.com/v1
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_PATH=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=T-Ride
SMTP_FROM_EMAIL=

# =============================================================================
# Optional: initial admin bootstrap values.
# Prefer interactive/secret-store input. Do not leave real values in files.
# =============================================================================
ADMIN_INITIAL_EMAIL=REPLACE_WITH_INITIAL_ADMIN_EMAIL_IF_USED
ADMIN_INITIAL_PASSWORD=REPLACE_WITH_TEMPORARY_INITIAL_ADMIN_PASSWORD_IF_USED
