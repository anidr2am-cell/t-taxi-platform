# T-Ride Backend environment template
# Copy to backend/.env on the target server. Never commit real .env files.

# =============================================================================
# Required runtime
# =============================================================================
NODE_ENV=production
PORT=3000
API_VERSION=v1
APP_NAME=T-Ride
TZ=Asia/Bangkok

# =============================================================================
# Required database
# =============================================================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ttaxi_staging
DB_USER=ttaxi_app
DB_PASSWORD=replace-with-strong-database-password
DB_CONNECTION_LIMIT=10

# =============================================================================
# Required JWT secrets
# =============================================================================
JWT_ACCESS_SECRET=replace-with-strong-random-access-secret
JWT_REFRESH_SECRET=replace-with-strong-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# Required public origins
# =============================================================================
CORS_ORIGIN=https://staging.example.com
PUBLIC_API_URL=https://staging.example.com
SOCKET_PATH=/socket.io

# =============================================================================
# Uploads and logs
# =============================================================================
UPLOAD_DIR=/var/lib/ttaxi/uploads
UPLOAD_MAX_FILE_SIZE_MB=10
LOG_LEVEL=info
LOG_DIR=/var/log/ttaxi

# =============================================================================
# Swagger / OpenAPI
# =============================================================================
SWAGGER_ENABLED=false
SWAGGER_ROUTE=/api-docs

# =============================================================================
# Optional Google Places proxy
# =============================================================================
GOOGLE_MAPS_API_KEY=

# =============================================================================
# Optional Aviationstack flight lookup
# =============================================================================
AVIATIONSTACK_API_KEY=
AVIATIONSTACK_BASE_URL=http://api.aviationstack.com/v1
AVIATIONSTACK_TIMEOUT_MS=5000

# =============================================================================
# Optional automatic flight sync worker
# Staging default: disabled. Use one backend instance only when enabled.
# =============================================================================
FLIGHT_SYNC_ENABLED=false
FLIGHT_SYNC_MIN_INTERVAL_MS=120000
FLIGHT_SYNC_INTERVAL_MS=300000
FLIGHT_SYNC_BATCH_SIZE=20
FLIGHT_SYNC_LOOKBACK_HOURS=6
FLIGHT_SYNC_LOOKAHEAD_HOURS=48
FLIGHT_SYNC_MAX_RETRIES=3
FLIGHT_SYNC_RETRY_BASE_MS=30000
FLIGHT_DELAY_NOTIFICATION_DELTA_MINUTES=15

# =============================================================================
# Optional SMTP email notifications
# Leave blank to skip email delivery safely.
# =============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=T-Ride
SMTP_FROM_EMAIL=
SMTP_FROM=

# =============================================================================
# Optional Firebase Admin / FCM
# Use either individual variables or FIREBASE_SERVICE_ACCOUNT_PATH.
# =============================================================================
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_PATH=

# =============================================================================
# Sensitive development-only flags
# Keep false in staging unless testing in an isolated environment.
# =============================================================================
ALLOW_DEV_QR_REISSUE=false
