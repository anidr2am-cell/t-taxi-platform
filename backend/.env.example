# TTaxi Backend — Environment template (Pack 18)
# Copy to .env and fill in values. Never commit .env to git.

# =============================================================================
# REQUIRED (all environments)
# =============================================================================

NODE_ENV=development
# production | development | test

DB_USER=ttaxi_app
DB_NAME=ttaxi
DB_PASSWORD=
# Production: non-empty password required (app exits on startup if missing)

JWT_ACCESS_SECRET=replace-with-min-16-char-random-secret
JWT_REFRESH_SECRET=replace-with-min-16-char-random-secret
# Production: must be strong random values (min 16 chars); weak patterns rejected

# =============================================================================
# SERVER
# =============================================================================

PORT=3000
API_VERSION=v1
APP_NAME=TTaxi
TZ=Asia/Bangkok

# =============================================================================
# CORS & PUBLIC URLS
# =============================================================================

CORS_ORIGIN=http://localhost:8080
# Production REQUIRED: explicit frontend origin(s), comma-separated; never *

PUBLIC_API_URL=http://localhost:3000
# Production RECOMMENDED: public API base URL for links in notifications

# =============================================================================
# DATABASE
# =============================================================================

DB_HOST=localhost
DB_PORT=3306
DB_CONNECTION_LIMIT=10

# =============================================================================
# JWT EXPIRY
# =============================================================================

JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# SOCKET.IO
# =============================================================================

SOCKET_PATH=/socket.io

# =============================================================================
# UPLOADS (settlement receipts — local storage in MVP)
# =============================================================================

UPLOAD_DIR=./uploads
UPLOAD_MAX_FILE_SIZE_MB=10
# Production: use persistent disk or plan object storage migration

# =============================================================================
# LOGGING
# =============================================================================

LOG_LEVEL=info
LOG_DIR=./logs

# =============================================================================
# SWAGGER / API DOCS
# =============================================================================

SWAGGER_ENABLED=true
# Production: set false or omit (defaults to false when NODE_ENV=production)

SWAGGER_ROUTE=/api-docs

# =============================================================================
# OPTIONAL INTEGRATIONS (safe to leave empty — features disable gracefully)
# =============================================================================

# Google Places proxy (backend-only)
GOOGLE_MAPS_API_KEY=

# Aviationstack flight lookup
AVIATIONSTACK_API_KEY=
AVIATIONSTACK_BASE_URL=http://api.aviationstack.com/v1
AVIATIONSTACK_TIMEOUT_MS=5000

# SMTP email notifications (skipped when SMTP_HOST empty)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Firebase Cloud Messaging (skipped when FIREBASE_PROJECT_ID empty)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Or path to service account JSON:
FIREBASE_SERVICE_ACCOUNT_PATH=
